{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Open AI Chat Action",
  "type": "object",
  "required": ["chatId", "target", "trigger", "isPinned"],
  "properties": {
    "chatId": {
      "description": "The ID of the chat to open",
      "type": "string"
    },
    "target": {
      "$ref": "types/open-target.json"
    },
    "trigger": {
      "description": "Whether the chat was opened via mouse click or keyboard",
      "type": "string",
      "enum": ["mouse", "keyboard"]
    },
    "isPinned": {
      "description": "Whether the chat is pinned",
      "type": "boolean"
    }
  }
}
