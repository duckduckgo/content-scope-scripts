{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Customizer Data",
  "type": "object",
  "required": [
    "background",
    "theme",
    "userImages"
  ],
  "properties": {
    "background": {"$ref": "./background.json"},
    "theme": { "$ref": "./browser-theme.json" },
    "userImages": {
      "type": "array",
      "items": {
        "$ref": "./user-image.json"
      }
    }
  }
}
