{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AiChat",
  "type": "object",
  "required": ["chatId", "title"],
  "properties": {
    "chatId": {
      "description": "Unique identifier for the chat",
      "type": "string"
    },
    "title": {
      "description": "Display title of the chat",
      "type": "string"
    },
    "pinned": {
      "description": "Whether the chat is pinned",
      "type": "boolean"
    },
    "lastEdit": {
      "description": "ISO timestamp of last edit",
      "type": "string"
    },
    "model": {
      "description": "The AI model the chat was conducted with. Either a `CustomModel` literal we know how to render an icon for, or any other model identifier (e.g. 'gpt-4o-mini') which renders the default chat-bubble icon.",
      "anyOf": [{ "$ref": "custom-model.json" }, { "type": "string" }]
    }
  }
}
