{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Omnibar Config",
  "type": "object",
  "required": [
    "mode"
  ],
  "properties": {
    "mode": {
      "title": "Omnibar Mode",
      "type": "string",
      "enum": ["search", "ai"]
    },
    "enableAi": {
      "title": "Enable Duck.ai",
      "type": "boolean",
      "default": true
    },
    "showAiSetting": {
      "title": "Show Duck.ai Setting",
      "type": "boolean",
      "default": true
    },
    "showCustomizePopover": {
      "title": "Show Customize Popover",
      "description": "Controls a popover that onboards users and points them towards how to disable the feature via the customizer",
      "type": "boolean",
      "default": false
    },
    "enableRecentAiChats": {
      "title": "Enable Recent AI Chats",
      "type": "boolean",
      "default": false
    },
    "aiModels": {
      "title": "AI Models",
      "description": "List of available AI models for the model selector",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "description": "Model identifier",
            "type": "string"
          },
          "name": {
            "description": "Display name",
            "type": "string"
          }
        }
      }
    }
  }
}
