{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Omnibar Config",
  "type": "object",
  "required": [
    "mode"
  ],
  "properties": {
    "tabId": {
      "oneOf": [{
        "type": "null"
      }, {
        "title": "Optional Tab Id",
        "type": "string"
      }]
    },
    "tabIds": {
      "oneOf": [{
        "type": "null"
      }, {
        "title": "Optional List of tab Ids",
        "type": "array",
        "items": {
          "type": "string"
        }
      }]
    },
    "mode": {
      "title": "Omnibar Mode",
      "type": "string",
      "enum": ["search", "ai"]
    },
    "enableAi": {
      "title": "Enable Duck.ai",
      "type": "boolean",
      "default": true
    },
    "showAiSetting": {
      "title": "Show Duck.ai Setting",
      "type": "boolean",
      "default": true
    }
  }
}
