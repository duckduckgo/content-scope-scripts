{
  "readme": "Config for tracker-protection integration tests with sample tracker data and surrogate rules.",
  "version": 1,
  "features": {
    "trackerProtection": {
      "state": "enabled",
      "exceptions": [],
      "settings": {
        "blockingEnabled": true,
        "ctlEnabled": true,
        "trackerData": "{\"trackers\":{\"tracker.example\":{\"domain\":\"tracker.example\",\"owner\":{\"name\":\"Tracker Inc\",\"displayName\":\"Tracker Inc\"},\"default\":\"block\",\"rules\":[{\"rule\":\"tracker\\\\.example/scripts/analytics\\\\.js\",\"surrogate\":\"analytics.js\"}]},\"allowed.example\":{\"domain\":\"allowed.example\",\"owner\":{\"name\":\"Allowed Inc\"},\"default\":\"ignore\",\"rules\":[]}},\"entities\":{\"Tracker Inc\":{\"domains\":[\"tracker.example\"],\"displayName\":\"Tracker Inc\",\"prevalence\":0.1}},\"domains\":{\"tracker.example\":\"Tracker Inc\"}}",
        "surrogates": "tracker.example/analytics.js application/javascript\nglobalThis.__surrogateLoaded = true;\n",
        "allowlist": {},
        "tempUnprotectedDomains": [],
        "userUnprotectedDomains": []
      }
    }
  },
  "unprotectedTemporary": []
}
