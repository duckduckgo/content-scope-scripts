{
    "readme": "Config with webEvents feature disabled - no webEvent messages should be sent",
    "version": 1,
    "unprotectedTemporary": [],
    "features": {
        "webDetection": {
            "state": "enabled",
            "hash": "test",
            "exceptions": [],
            "settings": {
                "detectors": {
                    "adwall": {
                        "fire_event_text": {
                            "match": {
                                "text": {
                                    "pattern": "ad ?block(er)? detected"
                                }
                            },
                            "triggers": {
                                "auto": {
                                    "state": "enabled",
                                    "when": {
                                        "intervalMs": [50]
                                    }
                                }
                            },
                            "actions": {
                                "fireEvent": {
                                    "type": "adwall"
                                }
                            }
                        }
                    }
                }
            }
        },
        "webEvents": {
            "state": "disabled",
            "hash": "test",
            "exceptions": []
        }
    }
}
